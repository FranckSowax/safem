# Configuration Supabase pour SAFEM - Gabon
# Copier ce fichier vers .env.local et remplir avec vos vraies valeurs

# URL de votre projet Supabase
NEXT_PUBLIC_SUPABASE_URL=https://votre-projet-id.supabase.co

# Clé API anonyme de Supabase (safe pour le côté client)
NEXT_PUBLIC_SUPABASE_ANON_KEY=votre-cle-anonyme-ici

# Optionnel: Clé de service pour les opérations admin (côté serveur uniquement)
# SUPABASE_SERVICE_ROLE_KEY=votre-cle-service-ici
